# Server
PORT=3005
NODE_ENV=development
CORS_ORIGIN=http://localhost:3004
# Comma-separated allow list (preferred over CORS_ORIGIN when present)
CORS_ORIGINS=http://localhost:3004,http://localhost:3001,http://localhost:3000

# Database (Control Plane DB)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=skuld
DB_PASSWORD=skuld
DB_DATABASE=skuld_controlplane
# Local-only convenience. Keep false in regulated/shared environments.
DB_SYNCHRONIZE=false

# Tenant Database Configuration
TENANT_DB_HOST=localhost
TENANT_DB_PORT=5432
TENANT_DB_PREFIX=skuld_tenant_

# JWT
JWT_SECRET=change-this-secret-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-this-refresh-secret-in-production
JWT_REFRESH_EXPIRES_IN=7d
# License signing (inject via vault/platform in production)
# LICENSE_SIGNING_PRIVATE_KEY_PEM=
# LICENSE_SIGNING_PUBLIC_KEY_PEM=
# LICENSE_SIGNING_KEY_ID=
# LICENSE_GRACE_PERIOD_DAYS=30

# Stripe (Payment Provider)
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
# SUBSCRIPTION_GRACE_PERIOD_DAYS=14
# Pricing + metering mappings (inject via vault/platform)
# STRIPE_PRICE_STARTER_MONTHLY=
# STRIPE_PRICE_STARTER_ANNUAL=
# STRIPE_PRICE_PROFESSIONAL_MONTHLY=
# STRIPE_PRICE_PROFESSIONAL_ANNUAL=
# STRIPE_PRICE_ENTERPRISE_MONTHLY=
# STRIPE_PRICE_ENTERPRISE_ANNUAL=
# STRIPE_DEFAULT_METER_ID=
# STRIPE_METER_BOT_RUNS=

# Email Provider (sendgrid | smtp)
EMAIL_PROVIDER=sendgrid
EMAIL_FROM=noreply@skuldbot.com

# SendGrid
SENDGRID_API_KEY=SG.xxx

# SMTP (if EMAIL_PROVIDER=smtp)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# AWS (Storage Provider)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=skuld-controlplane

# Microsoft Graph
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# App URL (for email links)
APP_URL=http://localhost:3004

# ------------------------------------------------------------------------------
# Regulated deployment policy
# ------------------------------------------------------------------------------
# In regulated environments DO NOT use .env files.
# Inject these variables from your platform/vault and keep ALLOW_DOTENV unset.
ALLOW_DOTENV=false

# Public lead intake hardening (required for /api/public/leads/intake)
CP_PUBLIC_LEADS_SHARED_SECRET=replace-with-vault-managed-secret
CP_PUBLIC_LEADS_ALLOWED_GATEWAYS=skuldbotweb
CP_PUBLIC_LEADS_MAX_CLOCK_SKEW_SECONDS=300
